*.db-wal
*.db-shm
*.sqlite
*.sqlite3
gekko.db*
data/
backups/
# Runtime per-user DB root (per RESEARCH A13 — `~/.gekko/{user_id}.db`).
# This path expands to a literal `~/.gekko/` directory if someone accidentally
# `mkdir`s it inside the repo; keep it ignored explicitly.
.gekko/

# Browser-fallback session state (Robinhood / Fidelity)
browser-sessions/
