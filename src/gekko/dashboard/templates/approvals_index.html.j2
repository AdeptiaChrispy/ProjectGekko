{% extends "base.html.j2" %}

{% block title %}Pending Approvals — Gekko{% endblock %}

{% block content %}
{# UI-SPEC §Surface 2 — Dashboard /approvals index (D-55, DASH-04).
   No inline <script> per CSP `script-src 'self'`.
   HTMX partial-card swaps via hx-post on each proposal card.
   HTMX polling (every 30s) on the proposal list container so new
   proposals surface without a manual reload (Plan 03-13 GAP 4).
#}
<h1 class="text-2xl font-semibold mb-4 mt-4">Pending Approvals</h1>

{# Proposal-card list container with HTMX polling.
   hx-trigger="every 30s" polls GET /approvals/poll every 30 seconds and
   replaces this container's innerHTML with the updated fragment.
   The modal-mount div is OUTSIDE this container so it is never cleared
   by the poll refresh (edit-size modal remains intact during polling). #}
<div id="proposals-list-container"
     hx-get="/approvals/poll"
     hx-trigger="every 30s"
     hx-target="#proposals-list-container"
     hx-swap="innerHTML">
  {% include "_proposals_list.html.j2" %}
</div>

{# Modal mount point for HTMX modal swaps (edit-size, etc.).
   Outside the polling container — not cleared by poll refreshes. #}
<div id="modal-mount"></div>
{% endblock %}
