{#
  Gekko dashboard base template — Plan 01-09 Task 3.

  Loads same-origin Tailwind CSS + vendored HTMX (NEVER a third-party
  CDN). Renders the PAPER banner at the top (REG-01 invariant; D-24
  forbids live in P1 so the banner is unconditionally green/PAPER) and
  the "Not investment advice" disclosure footer.

  Content-Security-Policy (defence-in-depth per T-01-09-08):
    `script-src 'self'` blocks any future template regression that
    accidentally embeds an external script. The SRI lint gate
    (tests/unit/test_dashboard_templates_sri.py) is the static guard;
    the CSP is the runtime guard.

  Subresource Integrity (SRI) policy:
    External `<script src="http(s)://">` tags MUST carry
    `integrity="sha384-..." crossorigin="anonymous"`. The HTMX script
    below is vendored same-origin so no SRI attribute is needed.
#}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="Content-Security-Policy"
        content="default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'">
  <title>{% block title %}Gekko{% endblock %}</title>
  <link rel="stylesheet" href="/static/tailwind.css">
  <script src="/static/htmx.min.js" defer></script>
</head>
<body class="min-h-screen flex flex-col">
  {# Paper-vs-live banner — Phase-2 (plan 02-05) introduces request.state.banner_mode.
     Plan 02-06 wires the live conditional via request.state; for plan 02-05 the
     dependency resolves to "PAPER" unconditionally (no Phase-1 regression). #}
  {% if request and request.state is defined and request.state.banner_mode is defined and request.state.banner_mode == "LIVE" %}
    <div class="banner-live-strong" role="alert" aria-live="polite" aria-atomic="true">
      [LIVE — REAL MONEY] Alpaca live trading is armed.
    </div>
  {% else %}
    <div class="banner-paper">PAPER</div>
  {% endif %}

  {# Kill-active banner mount — populated when request.state.kill_active is True
     (FastAPI dependency injects from app.state with 60s TTL per UI-SPEC §"Trigger logic").
     The route POST /kill also targets #kill-banner-mount with hx-swap="outerHTML". #}
  {% if request and request.state is defined and request.state.kill_active is defined and request.state.kill_active %}
    {% include "kill_active_banner.html.j2" %}
  {% else %}
    <div id="kill-banner-mount"></div>
  {% endif %}

  <header class="border-b bg-white p-4">
    <div class="max-w-3xl flex items-center justify-between">
      <a href="/strategies" class="text-xl font-semibold text-gray-900">Gekko</a>
      <nav class="flex gap-4 text-sm items-center">
        <a href="/strategies">Strategies</a>
        <a href="/spend">Spend</a>
        <a href="/settings">Settings</a>
        {# UI-SPEC §2a: KILL button always visible, top-right of header.
           When kill_active=True, button re-labels to UNKILL and targets the
           unkill modal route (state-of-button per UI-SPEC §2a). #}
        {% if request and request.state is defined and request.state.kill_active is defined and request.state.kill_active %}
          <button class="btn-kill"
                  hx-get="/unkill/confirm-modal"
                  hx-target="#modal-mount"
                  hx-swap="innerHTML"
                  aria-label="Open unkill confirmation. Resumes all trading.">
            UNKILL
          </button>
        {% else %}
          <button class="btn-kill"
                  hx-get="/kill/confirm-modal"
                  hx-target="#modal-mount"
                  hx-swap="innerHTML"
                  aria-label="Open kill switch confirmation. Stops all trading.">
            KILL
          </button>
        {% endif %}
      </nav>
    </div>
  </header>

  <main class="max-w-3xl w-full p-6">
    {% block content %}{% endblock %}
  </main>

  <footer class="footer">
    Gekko is personal trade-execution tooling acting on your authored strategy. Not investment advice.
  </footer>

  {# HTMX modal-mount slot — kill/unkill confirmation modals swap into here. #}
  <div id="modal-mount"></div>
</body>
</html>
