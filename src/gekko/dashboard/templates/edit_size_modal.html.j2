{# Edit-size HTMX modal partial — Plan 03-14 (D-62 slider redesign).
   Replaces the number-input modal shipped in Plan 03-05/03-11 with a
   native HTML range slider showing max shares, live dollar/percent readout,
   at-cap variant, and equity-fetch-failure variant.

   Returned by:
     GET  /approvals/{proposal_id}/edit-size   → initial render
     POST /approvals/{proposal_id}/edit-submit → re-render on cap error

   HTMX target: #modal-mount (innerHTML swap).
   On success the POST returns the updated _proposal_card.html.j2 partial;
   HTMX swaps the modal-mount and card in place.
   Cancel clears #modal-mount via /modal/close.

   Context variables:
     proposal_id           : str
     ticker                : str
     side                  : str  (BUY / SELL)
     qty                   : str  (proposed qty — slider initial value)
     ref_price             : str  (server-derived, not operator input)
     target_notional_usd   : str
     original_notional     : str  (precomputed: qty * ref_price)
     max_shares            : int  (floor(max_position_pct * equity / ref_price))
     account_equity_display: str  ("$X,XXX.XX" or "" when equity fetch failed)
     equity_fetch_failed   : bool (True when broker was unreachable)
     max_position_pct      : str  (strategy hard cap, e.g. "0.05")
     drift_error           : str | None  (plain-language cap error or None)

   Server-side gate: _check_edit_size_caps in edit_size_submit (unchanged).
   The slider max is a UI affordance; the server cap check is the authority.

   CSP note: updateSizeReadout() is defined in /static/edit-size-slider.js
   (script-src 'self') so the oninput attribute is CSP-safe.
#}
<div class="modal-backdrop" id="edit-modal">
  <div class="modal" role="dialog" aria-labelledby="edit-size-headline" aria-modal="true">
    <h2 id="edit-size-headline" class="modal-headline">
      Edit order size — {{ side }} {{ qty }} {{ ticker }} (~${{ original_notional }})
    </h2>
    <div class="modal-body">

      {% if drift_error %}
      <div class="login-error" role="alert" aria-live="assertive">
        {{ drift_error }}
      </div>
      {% endif %}

      <p class="form-help">
        Ref price: <strong>${{ ref_price }}</strong> &nbsp;&middot;&nbsp;
        Current order: <strong>{{ qty }} shares (~${{ original_notional }})</strong>
      </p>

      <form hx-post="/approvals/{{ proposal_id }}/edit-submit"
            hx-target="#modal-mount"
            hx-swap="innerHTML">
        <div class="form-stack">
          <label for="edit-qty">Quantity (shares)</label>
          <input type="range"
                 id="edit-qty"
                 name="qty"
                 min="1"
                 step="1"
                 max="{{ max_shares }}"
                 value="{{ qty }}"
                 required
                 data-ref-price="{{ ref_price }}"
                 data-equity="{{ account_equity_display }}"
                 data-max-pct="{{ max_position_pct }}"
                 class="edit-size-slider"
                 aria-describedby="size-readout"
                 oninput="updateSizeReadout(this)">
          <div id="size-readout" class="edit-size-readout" aria-live="polite"></div>

          {% if not equity_fetch_failed and max_shares == qty | int %}
          <p class="form-help">This is your maximum for this strategy.</p>
          {% endif %}

          {% if equity_fetch_failed %}
          <p class="form-help"><span style="color:#92400e">&#9888; Cap couldn't be confirmed (broker unreachable). Server will verify at submit.</span></p>
          {% endif %}
        </div>

        <div class="modal-actions">
          <a hx-get="/modal/close"
             hx-target="#modal-mount"
             hx-swap="innerHTML"
             class="btn-secondary">Cancel</a>
          <button type="submit" class="btn-primary">Approve at this size</button>
        </div>
      </form>

    </div>
  </div>
</div>
<script src="/static/edit-size-slider.js"></script>
