{# Edit-size HTMX modal partial — Plan 03-05 Task 3 (D-54), updated Plan 03-11.
   UI-SPEC §Surface 2 (dashboard HTMX modal shape).
   RESEARCH §Pattern 4 (HTMX modal + outerHTML/innerHTML swap).

   Returned by:
     GET  /approvals/{proposal_id}/edit-size   → initial render
     POST /approvals/{proposal_id}/edit-submit → re-render on cap error

   HTMX target: #modal-mount (innerHTML swap).
   On success the POST returns the updated _proposal_card.html.j2 partial;
   HTMX swaps the modal-mount and card in place.
   Cancel clears #modal-mount via /modal/close.

   Context variables:
     proposal_id        : str
     ticker             : str
     side               : str  (BUY / SELL)
     qty                : str  (current / pre-fill value)
     ref_price          : str  (server-derived, not operator input)
     target_notional_usd : str
     original_notional  : str  (precomputed: qty * ref_price)
     drift_error        : str | None  (plain-language cap error or None)

   Validation: _check_edit_size_caps (Plan 03-11).
   The 2% drift check (_drift_check) is NOT the gate for operator edits.
#}
<div class="modal-backdrop" id="edit-modal">
  <div class="modal" role="dialog" aria-labelledby="edit-size-headline" aria-modal="true">
    <h2 id="edit-size-headline" class="modal-headline">
      Edit order size — {{ side }} {{ qty }} {{ ticker }} (~${{ original_notional }})
    </h2>
    <div class="modal-body">

      {% if drift_error %}
      <div class="login-error" role="alert" aria-live="assertive">
        {{ drift_error }}
      </div>
      {% endif %}

      <p class="form-help">
        Ref price: <strong>${{ ref_price }}</strong> &nbsp;&middot;&nbsp;
        Current order: <strong>{{ qty }} shares (~${{ original_notional }})</strong>
      </p>
      <p class="form-help">
        Adjust quantity below. Max order size is enforced at submit.
      </p>

      <form hx-post="/approvals/{{ proposal_id }}/edit-submit"
            hx-target="#modal-mount"
            hx-swap="innerHTML">
        <div class="form-stack">
          <label for="edit-qty">New quantity</label>
          <input type="number"
                 id="edit-qty"
                 name="qty"
                 step="any"
                 min="0"
                 value="{{ qty }}"
                 required
                 autocomplete="off"
                 class="login-input"
                 aria-describedby="edit-qty-help">
          <p id="edit-qty-help" class="form-help">
            Enter the number of shares (fractional allowed).
          </p>
        </div>

        <div class="modal-actions">
          <a hx-get="/modal/close"
             hx-target="#modal-mount"
             hx-swap="innerHTML"
             class="btn-secondary">Cancel</a>
          <button type="submit" class="btn-primary">Approve at this size</button>
        </div>
      </form>

    </div>
  </div>
</div>
