{% extends "base.html.j2" %}

{% block title %}Strategies — Gekko{% endblock %}

{% block content %}
<h1 class="text-2xl font-semibold mb-4">Strategies</h1>
<p class="text-sm text-gray-500 mb-4">
  Owner: <span class="font-medium">{{ user_id }}</span>
</p>

{# Phase 5 / TRUST-04 Surface 6b: anomaly auto-demotion notice(s). Red,
   role="alert" aria-live="assertive" — interrupts to announce the safety
   event. Rendered for any strategy auto-demoted today; clears on the next
   clean-day page load (the PROPOSE-ONLY badge persists the result). #}
{% for n in anomaly_notices %}
<div class="anomaly-notice" role="alert" aria-live="assertive">
  🛑 <code>{{ n.strategy_name }}</code> auto-demoted to propose-only —
  single-day drawdown {{ n.drawdown_pct }}% (threshold {{ n.threshold_pct }}%).
  {{ n.cancelled_count }} pending auto-order(s) cancelled.
</div>
{% endfor %}

{% if strategies %}
<table class="bg-white shadow-sm rounded-md">
  <thead>
    <tr>
      <th>Name</th>
      <th>Version</th>
      <th>Watchlist</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    {% for s in strategies %}
    {% include "_strategy_row.html.j2" %}
    {% endfor %}
  </tbody>
</table>
{% else %}
<p class="text-sm text-gray-500 italic">
  No strategies yet. Author one via
  <code>gekko strategy create</code>.
</p>
{% endif %}
{% endblock %}
