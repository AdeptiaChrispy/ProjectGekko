{% extends "base.html.j2" %}

{% block title %}Strategies — Gekko{% endblock %}

{% block content %}
<h1 class="text-2xl font-semibold mb-4">Strategies</h1>
<p class="text-sm text-gray-500 mb-4">
  Owner: <span class="font-medium">{{ user_id }}</span>
</p>

{% if strategies %}
<table class="bg-white shadow-sm rounded-md">
  <thead>
    <tr>
      <th>Name</th>
      <th>Version</th>
      <th>Watchlist</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    {% for s in strategies %}
    {% include "_strategy_row.html.j2" %}
    {% endfor %}
  </tbody>
</table>
{% else %}
<p class="text-sm text-gray-500 italic">
  No strategies yet. Author one via
  <code>gekko strategy create</code>.
</p>
{% endif %}
{% endblock %}
